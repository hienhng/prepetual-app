# Database
DATABASE_URL=postgresql://user:password@localhost:5432/prepetual

# Session Security
SESSION_SECRET=your_super_secret_random_string

# AI Integrations (OpenAI)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxx
